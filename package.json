{
  "name": "vrbne-ical-service",
  "version": "1.0.0",
  "description": "iCal service for slalom course opening times with weather",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec ts-node src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ical",
    "calendar",
    "vrbne",
    "slalom"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "~1.15",
    "cheerio": "~1.0",
    "cors": "~2.8",
    "ejs": "~3.1",
    "express": "~4.22",
    "helmet": "~7.1",
    "ical-generator": "~7.0",
    "luxon": "~3.4",
    "markdown-it": "~14.1",
    "node-cache": "~5.1",
    "uuid": "~9.0"
  },
  "devDependencies": {
    "@types/cheerio": "~0.22",
    "@types/cors": "~2.8",
    "@types/express": "~4.17",
    "@types/luxon": "~3.7",
    "@types/markdown-it": "~14.1",
    "@types/node": "~20.12",
    "@types/node-cache": "~4.1",
    "@types/uuid": "~9.0",
    "nodemon": "~3.1",
    "ts-node": "~10.9",
    "typescript": "~5.4"
  }
}
